---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ParticleBackground from "../components/ParticleBackground";
import ProjectCard from "../components/ProjectCard";
---

<BaseLayout>
  <Navbar />

  <!-- ====== HERO ====== -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <ParticleBackground client:only="react" />
    </div>
    <div class="hero-orbs">
      <div class="hero-orb hero-orb--1"></div>
      <div class="hero-orb hero-orb--2"></div>
      <div class="hero-orb hero-orb--3"></div>
    </div>
    <main class="hero-content container" id="main-content">
      <div class="hero-badge animate-in">
        <span class="badge-dot"></span>
        <span class="badge-label">Indie Studio · Building the Future</span>
      </div>
      <h1 class="hero-title animate-in animate-in-delay-1">
        We craft products<br />people
        <span class="gradient-text--aurora">LOVE</span>
        <span class="hero-title-light">to use</span>
      </h1>
      <p class="hero-subtitle animate-in animate-in-delay-2" id="typewriter-text">
        <span class="typewriter-cursor">&nbsp;</span>
      </p>
      <div class="hero-actions animate-in animate-in-delay-3">
        <a href="#projects" class="btn-primary">
          <span>Explore our work</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 3v10M4 9l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#contact" class="btn-secondary">
          Get in touch
        </a>
      </div>
      <div class="hero-stats animate-in animate-in-delay-4">
        <div class="hero-stat">
          <span class="hero-stat-number" data-count="3">0</span>
          <span class="hero-stat-label">Products</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-number" data-count="4">0</span>
          <span class="hero-stat-label">Team Members</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-number">E2E</span>
          <span class="hero-stat-label">Encrypted</span>
        </div>
      </div>
    </main>
    <div class="hero-fade"></div>
    <div class="hero-grid-pattern"></div>
  </section>

  <!-- ====== ABOUT ====== -->
  <section class="section section--about" id="about">
    <div class="about-glow"></div>
    <div class="container">
      <div class="about-bento">
        <div class="bento-main">
          <span class="section-label">◈ About Us</span>
          <h2 class="section-title">
            Small team,<br /><span class="gradient-text">massive vision</span>
          </h2>
          <p class="about-desc">
            We're <strong>CatSoup Studios</strong> — an indie team obsessed with building
            beautiful, functional, and delightful digital products. No bloated feature lists,
            no corporate compromises. Just thoughtful software built with love.
          </p>
          <div class="about-highlights">
            <div class="highlight-item">
              <span class="highlight-icon">🔒</span>
              <span class="highlight-text">Privacy by default</span>
            </div>
            <div class="highlight-item">
              <span class="highlight-icon">⚡</span>
              <span class="highlight-text">Lightning fast</span>
            </div>
            <div class="highlight-item">
              <span class="highlight-icon">🎨</span>
              <span class="highlight-text">Pixel-perfect</span>
            </div>
          </div>
        </div>

        <div class="bento-card bento-card--quality">
          <div class="bento-card-icon">◈</div>
          <h3 class="bento-card-title">Quality First</h3>
          <p class="bento-card-desc">Every detail matters. We ship when it's ready, not when the calendar says so.</p>
        </div>

        <div class="bento-card bento-card--privacy">
          <div class="bento-card-icon">◇</div>
          <h3 class="bento-card-title">Privacy by Design</h3>
          <p class="bento-card-desc">Your data is yours. End-to-end encryption and zero-knowledge architecture.</p>
        </div>

        <div class="bento-card bento-card--open">
          <div class="bento-card-icon">△</div>
          <h3 class="bento-card-title">Open Source Spirit</h3>
          <p class="bento-card-desc">We give back to the community. Tools and knowledge, shared freely.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== FEATURES ====== -->
  <section class="section section--features" id="features">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-label">✦ Why Auroriah</span>
        <h2 class="section-title" style="text-align:center;">
          Everything you need,<br /><span class="gradient-text--aurora">nothing you don't</span>
        </h2>
        <p class="section-subtitle" style="margin:0 auto;">
          Auroriah is the social platform built for people who care about privacy, design, and community.
        </p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon-wrap"><span class="feature-icon">🔐</span></div>
          <h3 class="feature-title">End-to-End Encrypted</h3>
          <p class="feature-desc">Messages, calls, and files — all encrypted by default. Not even we can read them.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap feature-icon-wrap--purple"><span class="feature-icon">💬</span></div>
          <h3 class="feature-title">Real-Time Chat</h3>
          <p class="feature-desc">Instant messaging with rich media, reactions, threads, and lightning-fast delivery.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap feature-icon-wrap--pink"><span class="feature-icon">🎙️</span></div>
          <h3 class="feature-title">Voice Channels</h3>
          <p class="feature-desc">Drop into voice channels with your community. Crystal clear audio, zero latency.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap feature-icon-wrap--amber"><span class="feature-icon">✨</span></div>
          <h3 class="feature-title">Aura System</h3>
          <p class="feature-desc">Earn Aura through engagement. Unlock cosmetics, decorations, and exclusive rewards.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap feature-icon-wrap--emerald"><span class="feature-icon">🎨</span></div>
          <h3 class="feature-title">Custom Profiles</h3>
          <p class="feature-desc">Express yourself with ring decorations, card borders, banners, and animated effects.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon-wrap feature-icon-wrap--blue"><span class="feature-icon">📱</span></div>
          <h3 class="feature-title">Cross-Platform</h3>
          <p class="feature-desc">Available on iOS, Android, Windows, and macOS. Your world, everywhere you go.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== PROJECTS ====== -->
  <section class="section section--projects" id="projects">
    <div class="projects-bg-glow"></div>
    <div class="container">
      <div class="section-header">
        <span class="section-label">★ Our Work</span>
        <h2 class="section-title">
          Projects we're<br /><span class="gradient-text">proud of</span>
        </h2>
        <p class="section-subtitle">
          From concept to launch, we obsess over every detail. Here's what we've been building.
        </p>
      </div>

      <div class="projects-grid">
        <div class="project-featured-wrapper">
          <div class="featured-badge">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M8 1l2.2 4.5 5 .7-3.6 3.5.9 5L8 12.4 3.5 14.7l.9-5L.8 6.2l5-.7L8 1z" fill="currentColor"/>
            </svg>
            Featured Project
          </div>
          <ProjectCard
            client:visible
            title="Auroriah"
            description="A premium social platform with end-to-end encryption, real-time presence, and a vibrant community experience. Privacy-first architecture with encrypted DMs, live voice channels, customizable profiles, and the unique Aura farming system."
            status="live"
            featured={true}
            icon="✦"
            href="#"
            techStack={["React Native", "TypeScript", "Firebase", "E2EE", "Electron"]}
          />
        </div>

        <ProjectCard
          client:visible
          title="Project Nebula"
          description="Our next venture — a creative toolkit for digital artists. Stay tuned for something extraordinary."
          status="coming-soon"
          icon="◇"
          techStack={["Coming 2026"]}
        />
        <ProjectCard
          client:visible
          title="CatSoup Engine"
          description="Internal tools and systems that power everything we build. Modular, fast, and open-source soon."
          status="in-development"
          icon="⬡"
          techStack={["Node.js", "TypeScript"]}
        />
      </div>
    </div>
  </section>

  <!-- ====== TEAM ====== -->
  <section class="section section--team" id="team">
    <div class="container">
      <div class="section-header section-header--center">
        <span class="section-label">♦ The Team</span>
        <h2 class="section-title" style="text-align:center;">
          The people behind<br /><span class="gradient-text--warm">the magic</span>
        </h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          A small but mighty crew, obsessed with building the best.
        </p>
      </div>

      <div class="team-grid">
        <div class="team-card" data-tilt>
          <div class="team-card-shine"></div>
          <div class="team-avatar">
            <div class="avatar-glow"></div>
            <div class="avatar-ring">
              <span class="avatar-emoji">👑</span>
            </div>
          </div>
          <h3 class="team-name">Orianna</h3>
          <span class="team-role">CEO & Founder</span>
          <p class="team-bio">Visionary leader driving strategy, product direction, and the overall CatSoup mission.</p>
          <div class="team-tags">
            <span class="team-tag">Strategy</span>
            <span class="team-tag">Product</span>
          </div>
        </div>

        <div class="team-card" data-tilt>
          <div class="team-card-shine"></div>
          <div class="team-avatar">
            <div class="avatar-glow avatar-glow--blue"></div>
            <div class="avatar-ring avatar-ring--blue">
              <span class="avatar-emoji">⚡</span>
            </div>
          </div>
          <h3 class="team-name">Astra</h3>
          <span class="team-role team-role--blue">Lead Developer</span>
          <p class="team-bio">Full-stack engineer and architect. Turns complex ideas into elegant, working code.</p>
          <div class="team-tags">
            <span class="team-tag">React</span>
            <span class="team-tag">TypeScript</span>
            <span class="team-tag">Node.js</span>
          </div>
        </div>

        <div class="team-card" data-tilt>
          <div class="team-card-shine"></div>
          <div class="team-avatar">
            <div class="avatar-glow avatar-glow--purple"></div>
            <div class="avatar-ring avatar-ring--purple">
              <span class="avatar-emoji">🔍</span>
            </div>
          </div>
          <h3 class="team-name">Yulit</h3>
          <span class="team-role team-role--purple">QA Engineer</span>
          <p class="team-bio">Quality guardian. If there's a bug, she'll find it — and make sure it never comes back.</p>
          <div class="team-tags">
            <span class="team-tag">Testing</span>
            <span class="team-tag">QA</span>
          </div>
        </div>

        <div class="team-card" data-tilt>
          <div class="team-card-shine"></div>
          <div class="team-avatar">
            <div class="avatar-glow avatar-glow--pink"></div>
            <div class="avatar-ring avatar-ring--pink">
              <span class="avatar-emoji">🎨</span>
            </div>
          </div>
          <h3 class="team-name">DZDani</h3>
          <span class="team-role team-role--pink">UI/UX Designer</span>
          <p class="team-bio">Pixel-perfect creative mind. Crafts interfaces that feel both beautiful and intuitive.</p>
          <div class="team-tags">
            <span class="team-tag">UI/UX</span>
            <span class="team-tag">Figma</span>
            <span class="team-tag">Motion</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CONTACT/CTA ====== -->
  <section class="section section--contact" id="contact">
    <div class="cta-glow"></div>
    <div class="container">
      <div class="cta-block">
        <span class="section-label">◈ Get in Touch</span>
        <h2 class="cta-title">
          Let's build something<br /><span class="gradient-text--aurora">extraordinary</span>
        </h2>
        <p class="cta-subtitle">
          Have an idea? Want to collaborate? We'd love to hear from you. Drop us a line and let's create something amazing together.
        </p>
        <div class="cta-actions">
          <a href="mailto:hello@catsoupstudios.com" class="btn-primary btn-lg">
            <span>Say Hello</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#projects" class="btn-secondary">
            Explore Auroriah
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ====== HERO ====== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg { position: absolute; inset: 0; z-index: 0; }

  .hero-orbs { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.3;
    animation: float 8s ease-in-out infinite;
  }
  .hero-orb--1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(56,189,248,0.25), transparent 70%);
    top: -10%; left: -10%;
    animation-delay: 0s;
  }
  .hero-orb--2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(129,140,248,0.2), transparent 70%);
    top: 20%; right: -5%;
    animation-delay: 2s;
  }
  .hero-orb--3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(236,72,153,0.15), transparent 70%);
    bottom: 10%; left: 30%;
    animation-delay: 4s;
  }

  .hero-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 0;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black, transparent);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-top: var(--space-5xl);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    padding: var(--space-xs) var(--space-lg);
    margin-bottom: var(--space-2xl);
    backdrop-filter: blur(10px);
  }

  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent-emerald);
    box-shadow: 0 0 10px rgba(52,211,153,0.5);
    animation: pulse-glow 2s infinite;
  }

  .hero-title {
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-xl);
  }

  .hero-title-light {
    font-weight: 300;
    color: var(--text-secondary);
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 540px;
    margin: 0 auto var(--space-2xl);
    line-height: 1.8;
    min-height: 3.6em;
  }

  .typewriter-cursor {
    display: inline;
    border-right: 2px solid var(--accent-cyan);
    padding-right: 2px;
    animation: blink-cursor 0.8s step-end infinite;
  }

  @keyframes blink-cursor {
    0%, 100% { border-color: var(--accent-cyan); }
    50% { border-color: transparent; }
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-bottom: var(--space-3xl);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
    padding: var(--space-xl) var(--space-2xl);
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(10px);
    max-width: 480px;
    margin: 0 auto;
  }

  .hero-stat { text-align: center; }
  .hero-stat-number {
    display: block;
    font-size: 1.6rem;
    font-weight: 800;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }
  .hero-stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .hero-stat-divider {
    width: 1px; height: 36px;
    background: var(--border-subtle);
  }

  .hero-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 200px;
    background: linear-gradient(transparent, var(--bg-deep));
    z-index: 1;
    pointer-events: none;
  }

  /* ====== BUTTONS ====== */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    background: var(--gradient-accent);
    color: #0d0518;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius-full);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0);
    transition: background var(--transition-fast);
  }

  .btn-primary:hover::before { background: rgba(255,255,255,0.15); }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(56,189,248,0.3);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-subtle);
    transition: all var(--transition-base);
    background: rgba(255,255,255,0.02);
  }

  .btn-secondary:hover {
    color: var(--text-primary);
    border-color: var(--border-accent);
    background: rgba(56,189,248,0.05);
    transform: translateY(-2px);
  }

  .btn-lg {
    padding: var(--space-lg) var(--space-2xl);
    font-size: 1rem;
  }

  /* ====== ABOUT BENTO ====== */
  .section--about {
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .about-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 800px; height: 600px;
    background: radial-gradient(ellipse, rgba(56,189,248,0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .about-bento {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    grid-template-rows: auto auto auto;
    gap: var(--space-lg);
    position: relative;
    z-index: 1;
  }

  .bento-main {
    grid-row: 1 / 4;
    padding: var(--space-3xl) var(--space-2xl);
    background: var(--gradient-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: var(--space-md);
  }

  .about-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-highlights {
    display: flex;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: var(--space-sm) var(--space-md);
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
  }

  .highlight-icon { font-size: 1rem; }

  .bento-card {
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    transition: all var(--transition-slow);
    position: relative;
    overflow: hidden;
  }

  .bento-card::after {
    content: "";
    position: absolute;
    top: 0; left: 15%; right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-cyan), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .bento-card:hover {
    transform: translateY(-4px);
    border-color: rgba(56,189,248,0.15);
    background: var(--bg-card-hover);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }

  .bento-card:hover::after { opacity: 0.4; }

  .bento-card-icon {
    font-size: 1.3rem;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: var(--space-md);
  }

  .bento-card--privacy .bento-card-icon {
    background: var(--gradient-warm);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bento-card--open .bento-card-icon {
    background: var(--gradient-aurora);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .bento-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }

  .bento-card-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ====== FEATURES ====== */
  .section--features {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-deep) 100%);
    position: relative;
    overflow: hidden;
  }

  .section-header { margin-bottom: var(--space-3xl); }
